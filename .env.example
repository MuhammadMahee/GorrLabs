# ── RAG Pipeline (Priority tunings) ─────────────────────────
# Priority 1 — Hybrid search (vector + BM25 keyword)
ENABLE_RAG_HYBRID_SEARCH=true
RAG_HYBRID_BM25_WEIGHT=0.5

# Priority 2 — Relevance threshold (filters irrelevant chunks)
RAG_RELEVANCE_THRESHOLD=0.3

# Priority 3 — Embedding model (better English retrieval, 1.3GB)
RAG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# After changing this, re-embed all documents via Admin > Documents > Reset

# Priority 4 — Reranker (retrieve broad, rerank precisely)
RAG_TOP_K=20
RAG_RERANKING_MODEL=BAAI/bge-reranker-v2-m3
RAG_TOP_K_RERANKER=5

# Priority 5 — Semantic chunking (sentence-boundary, never splits mid-sentence)
RAG_TEXT_SPLITTER=semantic

# ── Docker Compose / CI secrets ──────────────────────────────
ARKIVE_SECRET_KEY=change-me-in-production
ARKIVE_PORT=8043
POSTGRES_DB=arkive
POSTGRES_USER=arkive
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5440

# ── Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# ── Amazon Bedrock
# Option A — plain IAM credentials (recommended)
AWS_ACCESS_KEY_ID=''        # AKIA... (20 chars)
AWS_SECRET_ACCESS_KEY=''    # 40-char IAM secret
# Option B — base64-encoded "accessKeyId:secretKey" (legacy)
AWS_BEDROCK_API_KEY=''
AWS_BEDROCK_REGION='ap-southeast-2'
AWS_BEDROCK_MODEL='qwen.qwen3-32b-v1:0'
AWS_BEDROCK_ENDPOINT_URL='' # leave empty for standard AWS; set for custom/third-party endpoints
ENABLE_BEDROCK_API='True'

# ── Routing enforcement (local_only fallback) ─────────────────────────
# Option A (current): Bedrock handles all queries including local_only.
#   Routing is audited correctly but not truly isolated to on-prem hardware.
LOCAL_FALLBACK_MODEL='qwen.qwen3-32b-v1:0'
#
# Option B (GPU Ollama — uncomment when GPU node is available):
# LOCAL_FALLBACK_MODEL='qwen2.5:7b'
# Also uncomment the GPU isolation block in backend/arkive/utils/middleware.py

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false